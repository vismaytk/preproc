# ──────────────────────────────────────────
# DataPrep Pro — Environment Variables
# Copy this file to .env and edit as needed
# ──────────────────────────────────────────

# Application
APP_NAME=DataPrep Pro
ENVIRONMENT=development  # development | production | testing

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True        # Set False in production
API_WORKERS=1          # Increase in production (e.g., 4)
API_URL=http://localhost:8000  # Full URL for the Streamlit frontend to reach the API

# Frontend
FRONTEND_PORT=8501

# CORS — comma-separated origins
# Development: localhost only. Production: add your deployed domain.
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# File Size Limits (in bytes)
MAX_CSV_SIZE=10485760   # 10MB
MAX_TXT_SIZE=5242880    # 5MB
MAX_IMAGE_SIZE=5242880  # 5MB

# Processing Limits
MAX_ROWS=1000000
MAX_COLUMNS=1000
SAMPLE_SIZE=5
MAX_TEXT_LENGTH=1000000
MAX_IMAGE_DIMENSION=4096
IMAGE_QUALITY=85

# Logging
LOG_LEVEL=INFO